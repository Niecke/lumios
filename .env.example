# PostgreSQL
POSTGRES_USER=lumios
POSTGRES_PASSWORD=
POSTGRES_DB=lumios
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# App
SECRET_KEY=
JWT_SECRET=
INIT_ADMIN_PASSWORD=
GUNICORN_WORKERS=

# Redis (optional — enables Redis-backed sessions; omit or leave empty to use filesystem sessions)
REDIS_URL=redis://redis:6379/0

# Google OAuth — backend SSR admin flow (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
LANDINGPAGE_URL=http://localhost:8082

# Google OAuth — frontend GIS flow (lumios-frontend OAuth client, no secret needed)
GOOGLE_FRONTEND_CLIENT_ID=

# MinIO (local dev S3-compatible storage)
MINIO_ROOT_USER=lumios
MINIO_ROOT_PASSWORD=

# S3-compatible object storage (point at MinIO locally, GCS/S3 in production)
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=lumios

BREVO_API_KEY=xxx
